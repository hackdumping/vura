{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/api/$1"
        },
        {
            "source": "/admin/(.*)",
            "destination": "/backend/admin/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/vura-forms/$1"
        }
    ]
}